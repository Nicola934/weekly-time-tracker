# Expo inlines EXPO_PUBLIC_* values into the bundle at build time.
# Physical Android builds cannot reach localhost or 127.0.0.1 on your computer.
# Set this to either your computer's LAN IP for local phone testing or a deployed API URL
# before running the APK build.
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000

# Example deployed backend:
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# Packaged Electron builds should use a deployed backend URL.
DESKTOP_API_BASE_URL=https://weekly-time-tracker.onrender.com

# Desktop-only fallback when the backend runs on the same machine:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
