# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./backend.db
SQL_ECHO=false
BACKEND_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,http://127.0.0.1:19006

# Frontend / Expo
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_ENABLE_DEV_FALLBACK=false
EXPO_PUBLIC_DISPLAY_NAME=Operator

# Desktop packaging
# Set this to your deployed backend before running `npm --prefix frontend run desktop:package`.
DESKTOP_API_BASE_URL=https://weekly-time-tracker.onrender.com
